# Copy this file to .env.local and fill values from your Aiven MySQL service
# Do NOT commit .env.local to source control.

# Aiven MySQL connection settings
MYSQL_HOST=cuan-app-abdurrohmanbilaol-7dd5.h.aivencloud.com
MYSQL_PORT=11719
MYSQL_DATABASE=defaultdb
MYSQL_USER=avnadmin
MYSQL_PASSWORD=YOUR_AIVEN_PASSWORD_HERE

# JWT secret for login sessions
# Must be at least 16 characters and identical in Vercel Production and Preview.
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

# SSL settings
# Set MYSQL_SSL_MODE=REQUIRED so the app enables SSL and uses MYSQL_SSL_CA
MYSQL_SSL_MODE=REQUIRED

# Paste the CA certificate here. Two safe ways:
# 1) Paste PEM exactly with real newlines (preferred when editing locally).
#    Example:
#    MYSQL_SSL_CA="-----BEGIN CERTIFICATE-----
#    MIID...rest of PEM...
#    -----END CERTIFICATE-----"
# 2) Or paste it as a single line using literal \n sequences. The code
#    will convert \n into real newlines automatically.
#    Example: MYSQL_SSL_CA="-----BEGIN CERTIFICATE-----\nMIID...\n-----END CERTIFICATE-----"
MYSQL_SSL_CA="-----BEGIN CERTIFICATE-----\nREPLACE_WITH_YOUR_CA_PEM\n-----END CERTIFICATE-----"

# Optional: set to false to disable server certificate verification (not recommended)
# MYSQL_SSL_REJECT_UNAUTHORIZED=true
