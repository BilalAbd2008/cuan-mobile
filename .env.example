MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=cuan_app
MYSQL_USER=root
MYSQL_PASSWORD=

# Di Vercel / hosting cloud: MYSQL_HOST harus hostname MySQL online (bukan 127.0.0.1 / Laragon).
# Impor schema + migration users ke database itu, lalu set variabel yang sama di Vercel → Environment Variables (Production).

# Wajib untuk login / sesi (string acak min. 16 karakter)
JWT_SECRET=ganti-dengan-string-acak-panjang-minimal-32-karakter
